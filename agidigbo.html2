<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGIDIGBO FM | Premium Live Radio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;700&family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="agidigbo.css" />
</head>
<body>
  <div class="page-shell">
    <header class="topbar">
      <div class="brand">
        <span class="mark">AGIDIGBO</span>
        <span class="sublabel">FM</span>
      </div>

      <nav class="nav-links" aria-label="Primary navigation">
        <a href="#live">Live</a>
        <a href="#programs">Programs</a>
        <a href="#presenters">Presenters</a>
        <a href="#news">News</a>
        <a href="#podcasts">Podcasts</a>
      </nav>

      <div class="nav-actions">
        <a class="btn btn-outline" href="#advertise">Advertise</a>
        <a class="btn btn-primary" href="#live">Listen Live</a>
      </div>
    </header>

    <main>
      <section class="hero" id="home">
        <div class="hero-copy">
          <p class="eyebrow">Luxury Radio. Cultural Authority.</p>
          <h1>Agidigbo FM — premium broadcasts that elevate every moment.</h1>
          <p class="hero-text">High-impact live radio, unrivaled presenter expertise, immersive podcasts, and curated news for audiences who expect excellence.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#live">Listen Live</a>
            <a class="btn btn-secondary" href="#podcasts">Explore Podcasts</a>
          </div>
          <div class="hero-highlights">
            <div class="highlight-card">
              <strong>24/7</strong>
              <span>Live streaming nationwide</span>
            </div>
            <div class="highlight-card">
              <strong>145K+</strong>
              <span>Active social community</span>
            </div>
            <div class="highlight-card">
              <strong>98%</strong>
              <span>Listener satisfaction</span>
            </div>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Live radio player">
          <div class="live-pill"><span class="pulse"></span> LIVE NOW</div>
          <div class="player-title">Agidigbo FM Live Stream</div>
          <div class="player-meta">
            <span>Now on air: The Morning Pulse</span>
            <span>Host: Ifeanyi Oyekunle</span>
          </div>
          <div class="audio-card">
            <audio controls preload="none">
              <source src="https://streaming.example.com/live.mp3" type="audio/mpeg" />
              Your browser does not support audio streaming.
            </audio>
            <div class="track-heading">
              <strong>On air</strong>
              <span>News, culture, music &amp; conversation</span>
            </div>
          </div>
          <div class="player-footer">
            <span>Live listeners</span>
            <strong>24,300+</strong>
          </div>
        </aside>
      </section>

      <section class="section" id="live">
        <div class="section-header">
          <p class="eyebrow">Live Broadcast Experience</p>
          <h2>Fast, flawless, and unforgettable radio for modern listeners.</h2>
        </div>
        <div class="program-grid">
          <article class="program-card">
            <span class="news-category">24/7</span>
            <h3>Round-the-clock content</h3>
            <p>Continuous live streaming with audio clarity, breaking news, and premium music curation.</p>
          </article>
          <article class="program-card">
            <span class="news-category">Trust</span>
            <h3>Audience-first journalism</h3>
            <p>Trusted reporting, verified updates, and editorial authority from a leading station.</p>
          </article>
          <article class="program-card">
            <span class="news-category">Culture</span>
            <h3>Culture & entertainment</h3>
            <p>Exclusive interviews, A-list voices, and community stories that reflect real life.</p>
          </article>
          <article class="program-card">
            <span class="news-category">Reach</span>
            <h3>Engagement across platforms</h3>
            <p>Powerful digital reach with social amplification, podcasts, and on-demand audio.</p>
          </article>
        </div>
      </section>

      <section class="section programs" id="programs">
        <div class="section-header">
          <p class="eyebrow">Featured Programs</p>
          <h2>Signature shows that define today’s conversation.</h2>
        </div>
        <div class="program-grid">
          <article class="program-card">
            <div class="program-visual program-news">News</div>
            <h3>Headline Review</h3>
            <p>Morning news, expert analysis, and stories shaping business, politics and society.</p>
            <span>Mon–Fri · 8AM</span>
          </article>
          <article class="program-card">
            <div class="program-visual program-culture">Culture</div>
            <h3>Culture Current</h3>
            <p>A celebration of arts, music, heritage and the fresh voices driving tomorrow.</p>
            <span>Sat · 2PM</span>
          </article>
          <article class="program-card">
            <div class="program-visual program-sports">Sports</div>
            <h3>Champion Circle</h3>
            <p>Live sports coverage, expert commentary, and unfiltered athlete storytelling.</p>
            <span>Sun · 6PM</span>
          </article>
          <article class="program-card">
            <div class="program-visual program-business">Business</div>
            <h3>Market Pulse</h3>
            <p>Daily economic insight, entrepreneurship features, and market narratives.</p>
            <span>Wed · 11AM</span>
          </article>
        </div>
      </section>

      <section class="section presenters" id="presenters">
        <div class="section-header">
          <p class="eyebrow">Meet Our Presenters</p>
          <h2>Voices with credibility, charisma and impact.</h2>
        </div>
        <div class="presenter-grid">
          <article class="presenter-card">
            <div class="presenter-photo presenter-photo-1"></div>
            <div class="presenter-body">
              <h3>Amara Okeke</h3>
              <span>Senior Anchor</span>
              <p>Leading daily conversations on current affairs, culture, and national progress.</p>
            </div>
          </article>
          <article class="presenter-card">
            <div class="presenter-photo presenter-photo-2"></div>
            <div class="presenter-body">
              <h3>Kunle Afolabi</h3>
              <span>Talk Show Host</span>
              <p>Hosting in-depth roundtables, leadership interviews, and live audience debates.</p>
            </div>
          </article>
          <article class="presenter-card">
            <div class="presenter-photo presenter-photo-3"></div>
            <div class="presenter-body">
              <h3>Ngozi Iwu</h3>
              <span>Culture Editor</span>
              <p>Curating stories on music, heritage, creative trends and social innovation.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="section newsroom" id="news">
        <div class="news-grid">
          <article class="news-hero">
            <p class="eyebrow">Latest News & Stories</p>
            <h2>Investigative reporting meets cultural storytelling.</h2>
            <p>Deeply sourced journalism, exclusive features and newsroom-first narratives for a connected audience.</p>
            <a class="btn btn-outline" href="#news">Explore Stories</a>
          </article>
          <article class="news-card">
            <span class="news-category">Editorial</span>
            <h3>Community voices shaping national agendas.</h3>
            <p>Powerful reporting on education, infrastructure and social impact.</p>
          </article>
          <article class="news-card">
            <span class="news-category">Spotlight</span>
            <h3>Exclusive interviews with cultural leaders.</h3>
            <p>Conversations that elevate voices and amplify bold perspectives.</p>
          </article>
          <article class="news-card last-card">
            <span class="news-category">Culture</span>
            <h3>Heritage stories for every generation.</h3>
            <p>Defining content that connects tradition with the digital era.</p>
          </article>
        </div>
      </section>

      <section class="section podcasts" id="podcasts">
        <div class="section-header">
          <p class="eyebrow">On Demand</p>
          <h2>Podcasts, conversations and audio series made to re-listen.</h2>
        </div>
        <div class="podcast-grid">
          <article class="podcast-card">
            <span class="episode-meta">Episode 21</span>
            <h3>Inside The Airwaves</h3>
            <p>Behind the scenes with station leaders and the creative force behind AGIDIGBO FM.</p>
            <strong>35 min</strong>
            <button type="button">Play Episode</button>
          </article>
          <article class="podcast-card">
            <span class="episode-meta">Episode 14</span>
            <h3>Voices of the Nation</h3>
            <p>Exploring culture, community and the future of media in West Africa.</p>
            <strong>42 min</strong>
            <button type="button">Play Episode</button>
          </article>
          <article class="podcast-card">
            <span class="episode-meta">Episode 08</span>
            <h3>Market Pulse Deep Dive</h3>
            <p>Business leaders discuss growth, policy, and the broadcast economy.</p>
            <strong>28 min</strong>
            <button type="button">Play Episode</button>
          </article>
        </div>
      </section>

      <section class="section testimonials" id="testimonials">
        <div class="section-header">
          <p class="eyebrow">Trusted by Listeners</p>
          <h2>Real praise from a loyal audience.</h2>
        </div>
        <div class="testimonial-grid">
          <article class="testimonial-card">
            <p>“Agidigbo FM delivers premium radio moments, curated storytelling and a powerful sense of trust. It’s my daily source for culture and conversation.”</p>
            <div class="testimonial-author">
              <strong>Chinwe N.</strong>
              <span>Media Enthusiast</span>
            </div>
          </article>
          <article class="testimonial-card">
            <p>“The station blends authority with entertainment in a way that feels luxurious and authentic. Every show is expertly produced and deeply resonant.”</p>
            <div class="testimonial-author">
              <strong>Emeka A.</strong>
              <span>Business Leader</span>
            </div>
          </article>
        </div>
      </section>

      <section class="section social" id="social">
        <div class="section-header">
          <p class="eyebrow">Social Reach</p>
          <h2>Audience engagement across every platform.</h2>
        </div>
        <div class="social-grid">
          <article class="social-card">
            <strong>145K</strong>
            <span>Instagram followers</span>
          </article>
          <article class="social-card">
            <strong>238K</strong>
            <span>Facebook community</span>
          </article>
          <article class="social-card">
            <strong>98K</strong>
            <span>Twitter listeners</span>
          </article>
          <article class="social-card">
            <strong>74K</strong>
            <span>Newsletter subscribers</span>
          </article>
        </div>
        <div class="social-icons">
          <a href="#" class="social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7a5 5 0 100 10 5 5 0 000-10zm0 8.2a3.2 3.2 0 110-6.4 3.2 3.2 0 010 6.4zm6.5-8.7a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0zM4 7.8V16c0 2.2 1.8 4 4 4h8c2.2 0 4-1.8 4-4V7.8c0-2.2-1.8-4-4-4H8C5.8 3.8 4 5.6 4 7.8zm2.5 0c0-.7.6-1.3 1.3-1.3h8.4c.7 0 1.3.6 1.3 1.3V16c0 .7-.6 1.3-1.3 1.3H7.8c-.7 0-1.3-.6-1.3-1.3V7.8z"/></svg>
            <span>Instagram</span>
          </a>
          <a href="#" class="social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 7H16V3.5h-3c-2 0-3.5 1.5-3.5 3.5V10H7v3.5h2.5V21H13V13.5h2.2l.3-3.5H13V7z"/></svg>
            <span>Facebook</span>
          </a>
          <a href="#" class="social-link" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 4.5c-.2 0-.4.1-.5.3-.2.2-.2.4 0 .6l5.5 5.5-5.5 5.5c-.2.2-.2.4 0 .6s.4.2.6 0l5.5-5.5 5.5 5.5c.2.2.4.2.6 0s.2-.4 0-.6L13.1 10.4l5.5-5.5c.2-.2.2-.4 0-.6s-.4-.2-.6 0l-5.5 5.5-5.5-5.5c-.1-.2-.3-.3-.5-.3z"/></svg>
            <span>X</span>
          </a>
          <a href="#" class="social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 15.5V8.5l6 3.5-6 3.5zm11-5.2c0-1-.8-1.8-1.8-1.8H4.8C3.8 8.5 3 9.3 3 10.3v3.8c0 1 .8 1.8 1.8 1.8h14.4c1 0 1.8-.8 1.8-1.8v-3.8z"/></svg>
            <span>YouTube</span>
          </a>
        </div>
      </section>

      <section class="section newsletter" id="contact">
        <div class="newsletter-card">
          <div>
            <p class="eyebrow">Stay Connected</p>
            <h2>Join our community for show alerts and exclusive drops.</h2>
            <p>Subscribe to the newsletter for premium station updates, podcast releases, and special invitations.</p>
          </div>
          <form class="newsletter-form">
            <label class="screen-reader-text" for="newsletter-email">Email address</label>
            <input id="newsletter-email" type="email" name="email" placeholder="Enter your email address" required />
            <button class="btn btn-primary" type="submit">Subscribe</button>
          </form>
        </div>
      </section>

      <section class="section cta-panel" id="advertise">
        <div class="cta-copy">
          <p class="eyebrow">Partner With Us</p>
          <h2>Amplify your brand with luxury radio reach.</h2>
          <p>Start a campaign, sponsor a show, or reach listeners through premium content and trusted authority.</p>
          <div class="cta-actions">
            <a class="btn btn-primary" href="#contact">Book A Campaign</a>
            <a class="btn btn-outline" href="#live">Start Streaming</a>
          </div>
        </div>
        <div class="hero-panel">
          <div class="live-pill"><span class="pulse"></span> Premium Studio</div>
          <div class="player-title">Your story deserves a powerful platform.</div>
          <p>Deliver your message with impact through trusted radio content, social resonance, and digital momentum.</p>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-grid">
        <div>
          <h4>AGIDIGBO FM</h4>
          <p>Leading the premium broadcast experience for news, culture and entertainment across West Africa.</p>
        </div>
        <div>
          <h4>Contact</h4>
          <a href="mailto:contact@agidigbofm.com">contact@agidigbofm.com</a>
          <a href="tel:+2348001234567">+234 800 123 4567</a>
        </div>
        <div>
          <h4>Quick links</h4>
          <a href="#live">Live Radio</a>
          <a href="#programs">Programs</a>
          <a href="#podcasts">Podcasts</a>
          <a href="#contact">Subscribe</a>
        </div>
      </div>
    </footer>
  </div>
</body>
</html>
